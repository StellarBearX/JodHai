generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id              String   @id @default(uuid())
  lineUserId      String   @unique @map("line_user_id")
  displayName     String   @unique @map("display_name")
  pin             String?
  budget          Float?
  cycleStartDay   Int      @default(1)  @map("cycle_start_day")
  budgetPeriod    String   @default("monthly") @map("budget_period")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt    @map("updated_at")

  transactions    Transaction[]
  trainingCases   TrainingCase[]
  chatLogs        ChatLog[]
  categoryBudgets CategoryBudget[]

  @@map("users")
}

// ─── CategoryBudget ───────────────────────────────────────────────────────────

model CategoryBudget {
  id       String @id @default(uuid())
  userId   String @map("user_id")
  category String
  amount   Float

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@map("category_budgets")
}

// ─── ChatLog ──────────────────────────────────────────────────────────────────

model ChatLog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  role      String   // "user" | "bot"
  kind      String   // "text" | "tx" | "image"
  content   String   // JSON
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("chat_logs")
}

// ─── TrainingCase ──────────────────────────────────────────────────────────────

model TrainingCase {
  id        String          @id @default(uuid())
  userId    String          @map("user_id")
  keyword   String
  category  String
  type      TransactionType
  createdAt DateTime        @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, keyword])
  @@index([userId])
  @@map("training_cases")
}

// ─── Transaction ──────────────────────────────────────────────────────────────

enum TransactionType {
  INCOME
  EXPENSE
}

model Transaction {
  id        String          @id @default(uuid())
  userId    String          @map("user_id")
  amount    Float
  type      TransactionType
  category  String
  note      String?
  createdAt DateTime        @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, createdAt])
  @@map("transactions")
}
